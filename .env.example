# goXero configuration
APP_NAME=goxero
APP_ENV=development
LOG_LEVEL=info

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

DB_HOST=localhost
DB_PORT=5432
DB_USER=goxero
DB_PASSWORD=goxero
DB_NAME=goxero
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=25
DB_MIN_CONNECTIONS=5
DB_MAX_CONN_LIFETIME=1h

# In production APP_ENV=production the app refuses to boot if JWT_SECRET is
# left at the insecure default below — generate with `openssl rand -hex 32`.
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=720h
TENANT_HEADER=Xero-Tenant-Id

# --- Bank feed integration (optional) -------------------------------------
# Leaving these blank disables the related adapter.
# GoCardless Bank Account Data (ex-Nordigen) — PSD2 aggregator, free tier.
# Register at https://bankaccountdata.gocardless.com/user-secrets/ to obtain
# secret_id / secret_key, then the app will pick it up at boot.
GOCARDLESS_BAD_SECRET_ID=
GOCARDLESS_BAD_SECRET_KEY=
# Where the bank consent UI sends the browser after the user confirms.
BANKFEED_REDIRECT_URL=http://localhost:5173/app/bank-feeds/callback
# How far back to pull statement lines on every /sync call.
BANKFEED_SYNC_WINDOW=2160h
